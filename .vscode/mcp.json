{
  "servers": {
    "abap-mcp": {
      "type": "stdio",
      "command": "c:\\Users\\Admin\\.vscode\\extensions\\harieprasad.abap-mcp-1.0.0\\bin\\abap-mcp.exe",
      "env": {
        "SAP_URL": "https://hostname:port",
        "SAP_USERNAME": "sap_username",
